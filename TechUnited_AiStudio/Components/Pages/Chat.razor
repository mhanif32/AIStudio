@page "/dashboard"
@page "/dashboard/{SessionId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using TechUnited_AiStudio.Models
@using TechUnited_AiStudio.Data
@using Microsoft.EntityFrameworkCore
@using TechUnited_AiStudio.Services
@using Markdig
@using System.Text.Json
@attribute [Authorize]
@inject OllamaService Ollama
@inject DocumentProcessingService DocService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<div class="chat-main-container">
    <div class="chat-messages-area" id="chat-box">
        @if (CurrentChat.Any())
        {
            @foreach (var msg in CurrentChat)
            {
                <div class="message-row @(msg.Role == "user" ? "user-row" : "ai-row")">
                    <div class="message-bubble shadow">
                        <div class="markdown-body">
                            @((MarkupString)Markdown.ToHtml(msg.Content))
                        </div>
                    </div>
                </div>
            }
            @if (isTyping)
            {
                <div class="message-row ai-row">
                    <div class="message-bubble typing-bubble">
                        <span class="spinner-grow spinner-grow-sm text-info"></span>
                        <span>@(isImageMode ? "Generating your masterpiece..." : isProcessingDoc ? "Analyzing document..." : "Thinking...")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="welcome-screen">
                <i class="bi bi-cpu text-info display-1"></i>
                <h3 class="mt-3">TechUnited AI Studio</h3>
                <p class="text-muted">Upload a PDF to "teach" the AI, or chat normally.</p>
            </div>
        }
    </div>

    <div class="chat-input-area">
        <div class="input-group custom-input-group shadow">
            <label class="btn btn-outline-secondary rounded-circle me-2" title="Upload Knowledge (PDF/DOCX/TXT)">
                <i class="bi bi-paperclip"></i>
                <InputFile OnChange="HandleFileImport" hidden accept=".pdf,.docx,.txt" />
            </label>

            <button class="btn @(isImageMode ? "btn-warning" : "btn-outline-secondary") rounded-circle me-2"
                    @onclick="ToggleImageMode" title="Toggle Image Generation">
                <i class="bi @(isImageMode ? "bi-image-fill" : "bi-image")"></i>
            </button>

            <input @bind="userInput" @bind:event="oninput" @onkeyup="HandleKeyUp"
                   class="form-control"
                   placeholder="@(isImageMode ? "Describe an image..." : "Ask a question about your docs...")"
                   disabled="@isTyping" />

            <button class="btn btn-info px-4" @onclick="SendMessage" disabled="@(isTyping || string.IsNullOrWhiteSpace(userInput))">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
</div>

<style>
    .chat-main-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 3.5rem);
        background: #0f172a;
        color: white;
    }

    .chat-messages-area {
        flex: 1;
        overflow-y: auto;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    .message-row {
        display: flex;
        width: 100%;
    }

    .user-row {
        justify-content: flex-end;
    }

    .ai-row {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 80%;
        padding: 1rem;
        border-radius: 1.25rem;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .user-row .message-bubble {
        background: #0ea5e9;
        color: white;
        border-bottom-right-radius: 4px;
    }

    .ai-row .message-bubble {
        background: #1e293b;
        color: #f1f5f9;
        border: 1px solid #334155;
        border-bottom-left-radius: 4px;
    }

    .typing-bubble {
        opacity: 0.7;
        font-style: italic;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .chat-input-area {
        padding: 1.5rem;
        background: #0f172a;
        border-top: 1px solid #1e293b;
    }

    .custom-input-group {
        background: #1e293b;
        border-radius: 50px;
        padding: 5px;
        border: 1px solid #334155;
        display: flex;
        align-items: center;
    }

        .custom-input-group input {
            background: transparent;
            border: none;
            color: white;
            padding-left: 1rem;
        }

            .custom-input-group input:focus {
                background: transparent;
                color: white;
                box-shadow: none;
            }

    .welcome-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        opacity: 0.4;
    }

    .markdown-body img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin-top: 10px;
        border: 1px solid #444;
    }
</style>

@code {
    [Parameter] public Guid? SessionId { get; set; }
    private string userInput = "";
    private bool isTyping = false;
    private bool isProcessingDoc = false;
    private bool isImageMode = false;
    private List<ChatMessage> CurrentChat = new();
    private Guid currentSessionId;

    protected override async Task OnParametersSetAsync()
    {
        currentSessionId = SessionId ?? Guid.NewGuid();
        if (SessionId.HasValue) await LoadChat(currentSessionId);
        else CurrentChat.Clear();
    }

    private void ToggleImageMode() => isImageMode = !isImageMode;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    private async Task HandleFileImport(InputFileChangeEventArgs e)
    {
        isTyping = true;
        isProcessingDoc = true;
        StateHasChanged();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        try
        {
            var chunks = await DocService.ExtractAndChunkAsync(e.File);
            using var db = await DbFactory.CreateDbContextAsync();

            foreach (var chunk in chunks)
            {
                var vector = await Ollama.GetEmbeddingAsync(chunk, isQuery: false);
                db.KnowledgeChunks.Add(new KnowledgeChunk
                {
                    FileName = e.File.Name,
                    Content = chunk,
                    VectorJson = JsonSerializer.Serialize(vector),
                    UserId = userId ?? "system",
                    CreatedAt = DateTime.Now
                });
            }
            await db.SaveChangesAsync();
            CurrentChat.Add(new ChatMessage { Role = "assistant", Content = $"Successfully processed **{e.File.Name}**. I've added {chunks.Count} knowledge segments to my memory." });
        }
        catch (Exception ex)
        {
            CurrentChat.Add(new ChatMessage { Role = "assistant", Content = $"Error processing file: {ex.Message}" });
        }
        finally
        {
            isTyping = false;
            isProcessingDoc = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }
    // logic 
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isTyping) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var originalText = userInput;
        userInput = "";
        isTyping = true;

        // 1. Save User Message to History
        var userMsg = new ChatMessage { ConversationId = currentSessionId, UserId = userId ?? "anon", Role = "user", Content = originalText, CreatedAt = DateTime.Now };
        CurrentChat.Add(userMsg);
        await SaveMsg(userMsg);
        StateHasChanged();

        try
        {
            // 2. RAG SEARCH: Find relevant data in the database
            var queryVector = await Ollama.GetEmbeddingAsync(originalText, isQuery: true);
            using var db = await DbFactory.CreateDbContextAsync();
            var userKnowledge = await db.KnowledgeChunks.Where(k => k.UserId == userId).ToListAsync();

            var topChunks = userKnowledge
                .Select(k => new { k.Content, Score = CalculateSimilarity(queryVector, JsonSerializer.Deserialize<float[]>(k.VectorJson) ?? Array.Empty<float>()) })
                .Where(x => x.Score > 0.45) // Lowered threshold slightly to be more helpful
                .OrderByDescending(x => x.Score)
                .Take(3)
                .Select(x => x.Content)
                .ToList();

            // 3. AUGMENT PROMPT: Tell the AI it HAS access to the file data
            string contextText = topChunks.Any()
                ? string.Join("\n\n", topChunks)
                : "No specific information found in uploaded documents.";

            string systemInstruction = $"You are a helpful assistant. You HAVE access to the user's uploaded files. Use the provided context to answer.\n\nCONTEXT FROM FILES:\n{contextText}";

            // 4. GET RESPONSE: Use the new method that handles history + system context
            var aiContent = await Ollama.GetChatResponse(CurrentChat, systemInstruction);

            var aiMsg = new ChatMessage { ConversationId = currentSessionId, UserId = userId ?? "anon", Role = "assistant", Content = aiContent, CreatedAt = DateTime.Now };
            CurrentChat.Add(aiMsg);
            await SaveMsg(aiMsg);
        }
        catch (Exception ex)
        {
            CurrentChat.Add(new ChatMessage { Role = "assistant", Content = $"Error: {ex.Message}" });
        }
        finally
        {
            isTyping = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }
    // Calculat

    private double CalculateSimilarity(float[] v1, float[] v2)
    {
        if (v1.Length != v2.Length || v1.Length == 0) return 0;
        float dot = 0, mag1 = 0, mag2 = 0;
        for (int i = 0; i < v1.Length; i++) { dot += v1[i] * v2[i]; mag1 += v1[i] * v1[i]; mag2 += v2[i] * v2[i]; }
        return dot / (Math.Sqrt(mag1) * Math.Sqrt(mag2));
    }

    private async Task SaveMsg(ChatMessage m) { using var db = await DbFactory.CreateDbContextAsync(); db.ChatMessages.Add(m); await db.SaveChangesAsync(); }
    private async Task LoadChat(Guid id) { using var db = await DbFactory.CreateDbContextAsync(); CurrentChat = await db.ChatMessages.Where(m => m.ConversationId == id).OrderBy(m => m.CreatedAt).ToListAsync(); }
    private async Task ScrollToBottom() => await JS.InvokeVoidAsync("eval", "const el = document.getElementById('chat-box'); if(el) el.scrollTop = el.scrollHeight;");
}